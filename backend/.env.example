# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# AWS Bedrock Configuration
# TODO: Configure your Bedrock model ID and region
# See: https://docs.aws.amazon.com/bedrock/latest/userguide/model-ids.html
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_REGION=us-east-1

# Amazon Q Developer Configuration
# TODO: Configure your Amazon Q Developer API endpoint
# See: https://docs.aws.amazon.com/amazonq/latest/qdeveloper-ug/what-is.html
Q_DEVELOPER_ENDPOINT=https://your-q-developer-endpoint.amazonaws.com
Q_DEVELOPER_API_KEY=your-api-key-here

# Cost Management
MAX_MONTHLY_COST=100.0
API_RATE_LIMIT_PER_MINUTE=60

# Agent Configuration
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2.0
MAX_FILES_PER_BATCH=100

# Execution Configuration
LAMBDA_TIMEOUT_SECONDS=900
LAMBDA_MEMORY_MB=10240
ECS_CPU=2048
ECS_MEMORY_MB=16384

# Storage Configuration
DATA_RETENTION_DAYS=90
S3_LIFECYCLE_ARCHIVE_DAYS=30

# DynamoDB Tables
DYNAMODB_WORKFLOWS_TABLE=cloudforge-workflows
DYNAMODB_BUGS_TABLE=cloudforge-bugs

# S3 Buckets
S3_ARTIFACTS_BUCKET=cloudforge-artifacts

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Development
ENVIRONMENT=development
DEBUG=false
